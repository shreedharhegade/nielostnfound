# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nielostnfound?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate-with: openssl rand -base64 32>

# Google OAuth (restrict to nie.ac.in domain in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin panel — comma-separated NIE admin email(s)
# Server-side guard (API routes)
ADMIN_EMAILS=admin@nie.ac.in

# Client-side — shows Admin link in navbar (safe: no secrets here)
NEXT_PUBLIC_ADMIN_EMAILS=admin@nie.ac.in
